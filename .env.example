# Copy this to .env and fill in values
# Railway: set these as environment variables in the service settings

# REQUIRED — generate a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-secret

# Path to SQLite DB — on Railway, mount a volume at /data and set this
DATABASE_PATH=/data/taskflow.db

# Must be "production" for the frontend to be served from Express
NODE_ENV=production

# Port (Railway sets this automatically, no need to change)
# PORT=3001
